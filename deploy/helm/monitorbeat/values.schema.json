{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "monitorweb": {
      "type": "object",
      "properties": {
        "image": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string"
        },
        "replicas": {
          "type": "integer",
          "minimum": 1
        },
        "service": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          }
        },
        "resources": {
          "type": "object"
        },
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "existingClaim": {
              "type": "string"
            },
            "accessMode": {
              "type": "string"
            },
            "size": {
              "type": "string"
            },
            "storageClass": {
              "type": "string"
            }
          }
        },
        "nodeSelector": {
          "type": "object"
        },
        "tolerations": {
          "type": "array"
        },
        "config": {
          "type": "object",
          "properties": {
            "listen": {
              "type": "string"
            },
            "db_path": {
              "type": "string"
            },
            "victoriametrics": {
              "type": "object",
              "properties": {
                "url": {
                  "type": "string"
                },
                "timeout": {
                  "type": "string"
                }
              }
            },
            "ui_dir": {
              "type": "string"
            },
            "alerts": {
              "type": "object",
              "not": {
                "required": ["db_path"]
              },
              "properties": {
                "eval_interval": {
                  "type": "string"
                }
              }
            },
            "registry": {
              "type": "object",
              "properties": {
                "ttl": {
                  "type": "string"
                },
                "clean_interval": {
                  "type": "string"
                }
              }
            },
            "smtp": {
              "type": "object",
              "properties": {
                "host": {
                  "type": "string"
                },
                "port": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 65535
                },
                "username": {
                  "type": "string"
                },
                "password": {
                  "type": "string"
                },
                "from": {
                  "type": "string"
                },
                "to": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "insecure": {
                  "type": "boolean"
                }
              }
            }
          }
        },
        "ingress": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "host": {
              "type": "string"
            },
            "tlsSecretName": {
              "type": "string"
            },
            "annotations": {
              "type": "object"
            }
          }
        }
      }
    }
  }
}
